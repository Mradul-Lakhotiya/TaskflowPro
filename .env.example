# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=task_manager
# Optionally use a direct connection string instead of separate components above
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/task_manager?sslmode=disable

# Backend Configuration
# Port used by Go server internally
PORT=8080
# Port exposed by Docker-compose
BACKEND_PORT=8080
JWT_SECRET=super_secret_jwt_key_change_in_production
# Secret key required in the X-Admin-Secret header to bootstrap an admin account
ADMIN_SECRET=super_secret_bootstrap_key_123
# Used for CORS allowed origins
FRONTEND_URL=http://localhost:3000

# Frontend Configuration
# Port exposed by Docker-compose
FRONTEND_PORT=3000
# The URL the frontend uses to talk to the backend (used by Docker or Next.js proxy)
API_URL=http://localhost:8080/api
